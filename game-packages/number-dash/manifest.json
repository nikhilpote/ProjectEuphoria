{
  "id": "number_dash",
  "name": "Number Dash",
  "version": "1.0.0",
  "description": "Numbers fall from the sky — tap them in order before they hit the bottom!",
  "layout": "fullscreen",
  "configSchema": {
    "difficulty": {
      "type": "string",
      "label": "Difficulty"
    },
    "maxNumber": {
      "type": "number",
      "label": "Highest number to reach",
      "min": 10,
      "max": 20
    },
    "cutoffScore": {
      "type": "number",
      "label": "Cutoff score (elimination threshold)",
      "min": 0,
      "max": 500
    }
  }
}
